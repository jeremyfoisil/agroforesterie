# Supabase — clé publique (anon). Visible dans le bundle navigateur :
# la sécurité repose sur les Row Level Security policies Supabase.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Mot de passe du panneau "Paramètres de tarification".
# Protection purement cosmétique — le JS est lisible côté client.
VITE_SETTINGS_PASSWORD=ChangeMe
